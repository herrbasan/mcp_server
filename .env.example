# LLM Gateway connection
# The orchestrator connects to an external LLM Gateway for all LLM work.
# WebSocket endpoint (streaming chat)
GATEWAY_URL=ws://localhost:3400/v1/realtime
# HTTP endpoint (embeddings)
GATEWAY_HTTP_URL=http://localhost:3400

# MCP Server binding
# Use 0.0.0.0 for remote access, localhost to restrict to local only
HOST=0.0.0.0
PORT=3100

# Memory settings (adjust based on your embedding model's token limit)
# For 512-token models: 1800  |  For 8192-token models: 30000
MAX_MEMORY_CHARS=30000

# Optional: Override the model used by a specific task type.
# These env vars take precedence over config.json when set.
# Model names must match what the LLM Gateway expects.
# DEFAULT_MODEL=my-chat-model        # Fallback for all tasks not set below
