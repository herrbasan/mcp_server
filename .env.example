# LM Studio REST API Endpoint
LM_STUDIO_ENDPOINT=http://localhost:1234

# Ollama REST API Endpoint
OLLAMA_ENDPOINT=http://localhost:11434

# Cloud Provider Endpoints (optional - defaults shown below)
# GEMINI_ENDPOINT=https://generativelanguage.googleapis.com/v1beta
# GROK_ENDPOINT=https://api.x.ai/v1
# KIMI_ENDPOINT=https://api.moonshot.cn/v1
# GLM_ENDPOINT=https://api.z.ai/api/paas/v4

# LLM Provider API Keys
GEMINI_API_KEY=your-gemini-api-key-here
GROK_API_KEY=your-grok-api-key-here
KIMI_API_KEY=your-kimi-api-key-here
GLM_API_KEY=your-glm-api-key-here

# LLM Models (Inference)
LM_STUDIO_MODEL=your-model-name-here
OLLAMA_MODEL=your-model-name-here
GEMINI_MODEL=gemini-flash-latest
OPENAI_MODEL=gpt-4o
GROK_MODEL=grok-4-1-fast-non-reasoning
KIMI_MODEL=kimi-k2.5
GLM_MODEL=glm-5

# Embedding Models (per-provider)
LM_STUDIO_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v2-moe
OLLAMA_EMBEDDING_MODEL=nomic-embed-text-v2-moe
GEMINI_EMBEDDING_MODEL=text-embedding-004
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
GROK_EMBEDDING_MODEL=text-embedding-3-small
# KIMI_CLI_COMMAND=kimi  # Path to Kimi CLI executable
# KIMI_EMBEDDING_MODEL=not-supported

# Memory settings (adjust based on your embedding model's token limit)
# For 512 token models: 1800, for 8192 token models: 30000
MAX_MEMORY_CHARS=30000

# MCP HTTP Server (for remote access)
MCP_HOST=0.0.0.0
MCP_PORT=3100

# Web Monitoring Interface
WEB_ENABLED=true
WEB_HOST=localhost
WEB_PORT=3010
WEB_MAX_LOGS=1000
