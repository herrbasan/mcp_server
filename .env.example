# LM Studio REST API Endpoint
LM_STUDIO_ENDPOINT=http://localhost:1234

# Default Models
LM_STUDIO_MODEL=nvidia/nemotron-3-nano
# Recommended: nomic-ai/nomic-embed-text-v1.5 (8192 tokens) or mxbai-embed-large (512 tokens)
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5

# Memory settings (adjust based on your embedding model's token limit)
# For 512 token models: 1800, for 8192 token models: 30000
MAX_MEMORY_CHARS=30000

# MCP HTTP Server (for remote access)
MCP_HOST=0.0.0.0
MCP_PORT=3100

# Web Monitoring Interface
WEB_ENABLED=true
WEB_HOST=localhost
WEB_PORT=3010
WEB_MAX_LOGS=1000
