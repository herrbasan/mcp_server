{
  "servers": {
    "lm-studio": {
      "enabled": true,
      "endpoint": "ws://192.168.0.100:12345",
      "model": "nvidia/nemotron-3-nano",
      "systemPrompt": "You provide concise second opinions on development decisions. Focus on performance, maintainability, and best practices.",
      "temperature": 0.7,
      "maxTokens": 4096
    },
    "code-analyzer": {
      "enabled": true,
      "description": "Analyzes code quality and suggests improvements"
    },
    "web-research": {
      "enabled": true,
      "llmEndpoint": "http://192.168.0.100:12345/v1/chat/completions",
      "llmModel": "nvidia/nemotron-3-nano",
      "maxPages": 10,
      "maxDepth": 2,
      "timeout": 180000,
      "searchEngines": ["duckduckgo", "google"],
      "description": "Multi-source web research with local LLM synthesis"
    },
    "memory": {
      "enabled": true,
      "embeddingEndpoint": "http://192.168.0.100:12345/v1/embeddings",
      "embeddingModel": "text-embedding-nomic-embed-text-v2-moe",
      "storePath": "data/memories.json",
      "description": "Persistent semantic memory across sessions"
    }
  },
  "orchestrator": {
    "name": "mcp-orchestrator",
    "version": "1.0.0"
  }
}
