{
  "workspaces": {
    "defaultMachine": "COOLKID",
    "machines": {
      "COOLKID": {
        "D:\\Work": "\\\\COOLKID\\Work\\Work",
        "D:\\DEV": "\\\\COOLKID\\DEV"
      },
      "FATTEN": {
        "E:\\Projects": "\\\\FATTEN\\Projects"
      }
    }
  },
  "servers": {
    "lm-studio": {
      "_taskType": "query",
      "enabled": true,
      "systemPrompt": "You provide concise second opinions on development decisions. Focus on performance, maintainability, and best practices.",
      "temperature": 0.7
    },
    "web-research": {
      "_taskTypes": ["analysis", "synthesis"],
      "enabled": true,
      "maxPages": 10,
      "maxDepth": 2,
      "timeout": 180000,
      "searchEngines": ["duckduckgo", "bing"],
      "description": "Multi-source web research with local LLM synthesis"
    },
    "memory": {
      "_taskType": "embedding",
      "enabled": true,
      "storePath": "data/memories.json",
      "description": "Persistent semantic memory across sessions"
    },
    "browser": {
      "enabled": true,
      "timeout": 30000,
      "maxContentSize": 2097152,
      "idleTimeout": 300000,
      "viewport": { "width": 1280, "height": 800 },
      "description": "Direct browser automation for LLMs - persistent browser with 5min idle timeout"
    },
    "local-agent": {
      "_taskType": "agent",
      "enabled": true,
      "maxTokenBudget": 50000,
      "maxIterations": 20,
      "model": null,
      "toolCallingFormat": "json-in-prompt",
      "description": "Autonomous local LLM agent with file access to remote workspaces via UNC paths"
    },
    "code-search": {
      "enabled": true,
      "indexPath": "data/indexes",
      "description": "Semantic code search for large codebases - tree-sitter + embeddings"
    }
  },
  "llm": {
    "defaultProvider": "lmstudio",
    "maxTokens": 32768,
    "taskDefaults": {
      "embedding": "lmstudio",
      "analysis": "lmstudio",
      "synthesis": "lmstudio",
      "query": "lmstudio",
      "agent": "lmstudio"
    },
    "_taskMapping": {
      "_comment": "Task defaults are used by the following servers:",
      "embedding": ["memory: embeddings for semantic search", "code-search: file embeddings"],
      "analysis": ["web-research: source selection and credibility analysis"],
      "synthesis": ["web-research: multi-source content synthesis"],
      "query": ["lm-studio: query_model and get_second_opinion tools"],
      "agent": ["local-agent: autonomous code analysis with tool calling"]
    },
    "providers": {
      "lmstudio": {
        "enabled": true,
        "type": "lmstudio",
        "endpoint": "${LM_STUDIO_ENDPOINT}",
        "model": "nvidia/nemotron-3-nano",
        "embeddingModel": "text-embedding-nomic-embed-text-v2-moe",
        "temperature": 0.7,
        "stripThinking": true,
        "connectTimeoutMs": 10000,
        "rpcTimeoutMs": 120000,
        "defaultModelTtlMs": 3600000,
        "nonDefaultModelTtlMs": 600000
      },
      "ollama": {
        "enabled": true,
        "type": "ollama",
        "endpoint": "http://192.168.0.145:11434",
        "model": "gemma3:12b",
        "embeddingModel": "nomic-embed-text-v2-moe",
        "temperature": 0.7
      },
      "gemini": {
        "enabled": true,
        "type": "gemini",
        "apiKey": "${GEMINI_API_KEY}",
        "model": "gemini-2.0-flash-exp",
        "embeddingModel": "text-embedding-004",
        "temperature": 0.7
      },
      "openai": {
        "enabled": false,
        "type": "openai",
        "apiKey": "${OPENAI_API_KEY}",
        "endpoint": "${LM_STUDIO_ENDPOINT}/v1/chat/completions",
        "model": "gpt-4o",
        "temperature": 0.7
      }
    }
  },
  "orchestrator": {
    "name": "mcp-orchestrator",
    "version": "1.0.0"
  },
  "web": {
    "enabled": true,
    "host": "localhost",
    "port": 3010,
    "maxLogs": 1000
  }
}
