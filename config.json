{
  "orchestrator": {
    "name": "mcp-orchestrator",
    "version": "2.0.0",
    "host": "0.0.0.0",
    "port": 3100
  },
  "gateway": {
    "wsUrl": "ws://localhost:3400/v1/realtime",
    "httpUrl": "http://localhost:3400"
  },
  "nIndexer": {
    "wsUrl": "ws://localhost:3666",
    "connectTimeout": 15000,
    "requestTimeout": 30000,
    "reconnectInterval": 5000,
    "maxReconnectAttempts": 5,
    "reconnectIntervalAfterMax": 15000
  },
  "agents": {
    "browser": {
      "viewport": { "width": 1280, "height": 1800 },
      "userDataDir": "data/chrome-profile"
    },
    "memory": {
      "storePath": "data/memories.json"
    },
    "research": {
      "maxPages": 10,
      "maxDepth": 2,
      "timeout": 300000,
      "searchEngines": ["google", "duckduckgo"]
    },
    "codebase": {
      "dataDir": "data/codebases"
    },
    "vision": {
      "ttlMinutes": 30,
      "mediaServiceUrl": "http://localhost:3500"
    }
  }
}
