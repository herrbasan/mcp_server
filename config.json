{
  "orchestrator": {
    "name": "mcp-orchestrator",
    "version": "2.0.0",
    "host": "0.0.0.0",
    "port": 3100
  },
  "gateway": {
    "wsUrl": "ws://localhost:3400/v1/realtime",
    "httpUrl": "http://localhost:3400"
  },
  "nMediaUrl": "http://localhost:3500",
  "agents": {
    "browser": {
      "viewport": { "width": 1280, "height": 1800 },
      "userDataDir": "data/chrome-profile"
    },
    "memory": {
      "storePath": "data/memories.json"
    },
    "research": {
      "maxPages": 10,
      "maxDepth": 2,
      "timeout": 300000,
      "searchEngines": ["google", "duckduckgo"]
    },
    "vision": {
      "ttlMinutes": 30
    },
    "forge": {
      "defaultTimeout": 300000,
      "maxTimeout": 600000
    },
    "dreaming": {
      "intervalMinutes": 60,
      "contextBudget": 800000,
      "autoStart": true,
      "distillerTask": "query",
      "dreamerTask": "query"
    }
  }
}
