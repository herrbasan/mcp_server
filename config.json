{
  "workspaces": {
    "COOLKID-Work": "\\\\COOLKID\\Work",
    "BADKID-DEV": "d:\\DEV",
    "BADKID-SRV": "d:\\SRV"
  },
  "maintenance": {
    "enabled": true,
    "indexRefreshIntervalMs": 900000,
    "_comment": "indexRefreshIntervalMs: 60000 = 1 minute, 300000 = 5 minutes, 900000 = 15 minutes, 3600000 = 1 hour, 86400000 = 24 hours"
  },
  "servers": {
    "llm": {
      "enabled": true,
      "systemPrompt": "You provide concise second opinions on development decisions. Focus on performance, maintainability, and best practices.",
      "temperature": 0.7
    },
    "web-research": {
      "enabled": true,
      "maxPages": 10,
      "maxDepth": 2,
      "timeout": 180000,
      "searchEngines": ["google", "duckduckgo"],
      "description": "Multi-source web research with local LLM synthesis"
    },
    "memory": {
      "_taskType": "embedding",
      "enabled": true,
      "storePath": "data/memories.json",
      "description": "Persistent semantic memory across sessions"
    },
    "browser": {
      "enabled": true,
      "timeout": 30000,
      "maxContentSize": 2097152,
      "idleTimeout": 300000,
      "viewport": { "width": 1280, "height": 800 },
      "userDataDir": "d:\\DEV\\mcp_server\\data\\chrome-profile",
      "description": "Direct browser automation for LLMs - persistent browser with 5min idle timeout"
    },
    "local-agent": {
      "enabled": true,
      "maxTokenBudget": 50000,
      "maxIterations": 20,
      "model": null,
      "toolCallingFormat": "json-in-prompt",
      "description": "Autonomous local LLM agent with file access to remote workspaces via UNC paths"
    },
    "code-search": {
      "enabled": true,
      "indexPath": "data/indexes",
      "description": "Semantic code search for large codebases - tree-sitter + embeddings"
    }
  },
  "llm": {
    "defaultProvider": "lmstudio",
    "embeddingProvider": "lmstudio",
    "providers": {
      "lmstudio": {
        "enabled": true,
        "type": "lmstudio",
        "endpoint": "${LM_STUDIO_ENDPOINT}",
        "model": "${LM_STUDIO_MODEL}",
        "embeddingModel": "text-embedding-nomic-embed-text-v2-moe",
        "temperature": 0.7,
        "stripThinking": true,
        "connectTimeoutMs": 10000,
        "rpcTimeoutMs": 120000,
        "defaultModelTtlMs": 3600000,
        "nonDefaultModelTtlMs": 600000
      },
      "ollama": {
        "enabled": true,
        "type": "ollama",
        "endpoint": "${OLLAMA_ENDPOINT}",
        "model": "${OLLAMA_MODEL}",
        "embeddingModel": "nomic-embed-text-v2-moe",
        "temperature": 0.7
      },
      "gemini": {
        "enabled": true,
        "type": "gemini",
        "apiKey": "${GEMINI_API_KEY}",
        "model": "${GEMINI_MODEL}",
        "embeddingModel": "text-embedding-004",
        "temperature": 0.7
      },
      "openai": {
        "enabled": false,
        "type": "openai",
        "apiKey": "${OPENAI_API_KEY}",
        "endpoint": "${LM_STUDIO_ENDPOINT}/v1/chat/completions",
        "model": "gpt-4o",
        "temperature": 0.7
      }
    }
  },
  "orchestrator": {
    "name": "mcp-orchestrator",
    "version": "1.0.0"
  },
  "web": {
    "enabled": true,
    "host": "localhost",
    "port": 3010,
    "maxLogs": 1000
  }
}
