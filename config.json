{
  "orchestrator": {
    "name": "mcp-orchestrator",
    "version": "2.0.0",
    "host": "0.0.0.0",
    "port": 3100
  },
  "gateway": {
    "wsUrl": "ws://localhost:3400/v1/realtime",
    "httpUrl": "http://localhost:3400"
  },
  "models": {
    "_comment": "Model names as known by the LLM Gateway. Use the exact model identifier the Gateway expects.",
    "query": "glm5-turbo-chat",
    "inspect": "glm5-turbo-chat",
    "synthesis": "glm5-turbo-chat",
    "analysis": "glm5-turbo-chat",
    "embed": "lmstudio-embed",
    "vision": "kimi-chat"
  },
  "spaces": {
    "COOLKID-Work": ["\\\\COOLKID\\Work\\Work", "d:\\Work"],
    "BADKID-DEV": ["\\\\BADKID\\Stuff\\DEV", "d:\\DEV"],
    "BADKID-SRV": ["\\\\BADKID\\Stuff\\SRV", "d:\\SRV"]
  },
  "nIndexer": {
    "wsUrl": "ws://localhost:3666",
    "connectTimeout": 5000,
    "requestTimeout": 30000,
    "reconnectInterval": 3000,
    "maxReconnectAttempts": 5
  },
  "agents": {
    "browser": {
      "timeout": 30000,
      "maxContentSize": 2097152,
      "idleTimeout": 300000,
      "viewport": { "width": 1280, "height": 1800 },
      "userDataDir": "data/chrome-profile"
    },
    "memory": {
      "storePath": "data/memories.json"
    },
    "research": {
      "maxPages": 10,
      "maxDepth": 2,
      "timeout": 300000,
      "searchEngines": ["google", "duckduckgo"]
    },
    "codebase": {
      "dataDir": "data/codebases",
      "embeddingDimension": 768,
      "maxFileSize": 1048576,
      "maintenance": {
        "enabled": true,
        "intervalMs": 3600000,
        "autoRefresh": true,
        "staleThresholdMs": 300000
      }
    },
    "vision": {
      "ttlMinutes": 30,
      "mediaServiceUrl": "http://localhost:3500"
    }
  }
}
