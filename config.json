{
  "workshop": {
    "name": "mcp-workshop",
    "version": "2.0.0",
    "host": "0.0.0.0",
    "port": 3100
  },
  "gateway": {
    "wsUrl": "ws://localhost:3400/v1/realtime",
    "httpUrl": "http://localhost:3400",
    "accessKey": null
  },
  "nMediaUrl": "http://localhost:3500",
  "agents": {
    "browser": {
      "viewport": { "width": 1280, "height": 1800 },
      "userDataDir": "data/chrome-profile"
    },
    "memory": {
      "dbPath": "data/memories.jsonl",
      "maxMemoryChars": 6000
    },
    "research": {
      "maxPages": 10,
      "maxDepth": 2,
      "timeout": 300000,
      "searchEngines": ["google", "duckduckgo"]
    },
    "vision": {
      "ttlMinutes": 30
    },
    "dreaming": {
      "intervalMinutes": 15,
      "contextBudget": 800000,
      "autoStart": true,
      "distillerTask": "query",
      "dreamerTask": "query",
      "serendipity": {
        "enabled": true,
        "wildcardBoost": 3,
        "resurfaceThresholdCycles": 5,
        "resurfaceChance": 0.3,
        "scoreJitter": 0.05,
        "scoreFloor": 0.15,
        "jitterCeiling": 0.80,
        "seed": null
      }
    },
    "storage": {
      "root": "D:\\MCP_Storage",
      "uncShare": "\\\\BADKID\\Stuff\\MCP_Storage",
      "publicUrl": "http://192.168.0.100:3100",
      "maxReadSize": 10485760,
      "maxWriteSize": 104857600
    },
    "documentation": {
      "llmDocsPath": "D:\\DEV\\LLM_Docs"
    },
    "vdb": {
      "enabled": true,
      "dbPath": "data/nvdb",
      "scanIntervalMinutes": 5,
      "scanTimeoutMinutes": 30,
      "embeddingModel": "or-qwen-embed",
      "embeddingDim": 2560,
      "chunkMaxTokens": 1024,
      "chunkOverlapTokens": 128,
      "chunkTokCharsRatio": 2.5,
      "maxFileSizeBytes": 10485760,
      "batchTokenLimit": 29000,
      "maxBatchTexts": 32,
      "filesPerGroup": 100,
      "maxRetries": 1,
      "batchDelayMs": 100,
      "textExtensions": [".md", ".txt", ".json", ".js", ".mjs", ".css", ".html", ".htm", ".log", ".yaml", ".yml", ".xml", ".csv", ".tsv", ".sql"],
      "ignore": ["forge", "temp"],
      "contextEnhancement": {
        "enabled": true,
        "task": "local",
        "maxInputChars": 60000,
        "maxOutputTokens": 512,
        "temperature": 0.3,
        "truncation": "headmidtail"
      },
      "watch": {
        "storage": { "enabled": true },
        "documentation": { "enabled": true }
      }
    },
    "forge": {
      "publicUrl": "http://192.168.0.100:3100",
      "defaultTimeout": 300000,
      "maxTimeout": 600000,
      "maxPayloadSize": 104857600,
      "maxPayloadItems": 10,
      "maxConcurrentCalls": 8,
      "queueTimeout": 30000,
      "maxReturnSize": 10240,
      "maxRollbackSnapshots": 10,
      "allowedPackages": [],
      "requireApprovalForNewPackages": true
    }
  }
}
